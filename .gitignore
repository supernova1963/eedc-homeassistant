# Data (wird als Volume gemountet)
eedc/data/*.db
eedc/data/*.sqlite
# Anwender-DB grundsätzlich nie tracken (auch nicht als 0-Byte-Stub)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Testing
.coverage
htmlcov/
.claude/

# SQLite Backup-Begleitdateien (WAL + Shared-Memory) — entstehen während
# des HA-Backup-WAL-Checkpoint-Hooks (#266) parallel zur .bak-Datei und
# enthalten flüchtige Transaktionsdaten. Pattern ist bewusst breit, damit
# zusätzliche Backup-Targets oder Test-Snapshots automatisch mit greifen.
eedc/data/*-wal
eedc/data/*-shm

# HA-Add-on-Backup-Begleitdatei der Anwender-DB (#280). Greift nicht über die
# generischen *.db-Patterns — die Endung ist .bak. Bewusst breit, damit weitere
# Backup-Targets oder Test-Snapshots in eedc/data/ automatisch mitgreifen.
eedc/data/*.bak

# Lokale Drafts: HANDOVER/AUDIT/PLAN/STAND-Files, die nur zwischen den beiden
# Entwicklungsrechnern via scripts/sync-claude.sh ausgetauscht werden — nicht
# nach GitHub. Verbleibende Verbreitung ausschließlich gernot-iMac14-1 ↔ gernot001.
docs/drafts/
